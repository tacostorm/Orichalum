<div class="nexus-panel-inner">

  {{!-- Search + New button toolbar --}}
  <div class="nexus-toolbar">
    <div class="nexus-search-wrap">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input class="nexus-search" type="text"
             placeholder="{{localize 'NEXUSNOTES.Panel.SearchPlaceholder'}}"
             value="{{searchQuery}}">
    </div>
    {{#unless isGM}}
      <button type="button" class="nexus-btn-new"
              data-action="newNote" data-vault-id="{{myVaultId}}"
              title="{{localize 'NEXUSNOTES.Panel.NewNote'}}">
        <i class="fa-solid fa-plus"></i> {{localize "NEXUSNOTES.Panel.NewNote"}}
      </button>
    {{/unless}}
  </div>

  {{!-- No-GM warning --}}
  {{#if noGM}}
    <div class="nexus-notice nexus-notice-warn">
      <i class="fa-solid fa-triangle-exclamation"></i>
      <p>{{localize "NEXUSNOTES.Panel.NoGM"}}</p>
    </div>

  {{else}}

    {{!-- ── MY NOTES ─────────────────────────────────────────────────── --}}
    <section class="nexus-section">
      <div class="nexus-section-header">
        <h3>{{localize "NEXUSNOTES.Panel.MyNotes"}}</h3>
        <button type="button" class="nexus-btn-icon"
                data-action="newNote" data-vault-id="{{myVaultId}}"
                title="{{localize 'NEXUSNOTES.Panel.NewNote'}}">
          <i class="fa-solid fa-plus"></i>
        </button>
      </div>
      <div class="notes-list">
        {{#if myNotes.length}}
          {{#each myNotes}}
            <div class="note-card {{#if pinned}}is-pinned{{/if}}" data-note-id="{{id}}">
              <div class="note-card-main">
                <div class="note-card-title">
                  {{#if pinned}}<i class="fa-solid fa-thumbtack pin-icon" title="{{localize 'NEXUSNOTES.Action.Pinned'}}"></i>{{/if}}
                  <span>{{title}}</span>
                  <span class="vis-badge vis-{{visibility}}">{{visibility}}</span>
                </div>
                {{#if _subject}}
                  <div class="note-subject">
                    <i class="fa-solid {{_subject.icon}}"></i>
                    <span>{{_subject.label}}</span>
                  </div>
                {{/if}}
                {{#if tags.length}}
                  <div class="note-tags">
                    {{#each tags}}<span class="tag-chip">{{this}}</span>{{/each}}
                  </div>
                {{/if}}
              </div>
              <div class="note-card-actions">
                <button type="button" class="nexus-btn-icon"
                        data-action="editNote"
                        data-vault-id="{{../myVaultId}}"
                        data-note-id="{{id}}"
                        title="{{localize 'NEXUSNOTES.Action.Edit'}}">
                  <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button type="button" class="nexus-btn-icon {{#if pinned}}active{{/if}}"
                        data-action="togglePin"
                        data-vault-id="{{../myVaultId}}"
                        data-note-id="{{id}}"
                        title="{{localize 'NEXUSNOTES.Action.TogglePin'}}">
                  <i class="fa-solid fa-thumbtack"></i>
                </button>
                <button type="button" class="nexus-btn-icon nexus-btn-danger"
                        data-action="deleteNote"
                        data-vault-id="{{../myVaultId}}"
                        data-note-id="{{id}}"
                        title="{{localize 'NEXUSNOTES.Action.Delete'}}">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            </div>
          {{/each}}
        {{else}}
          <p class="nexus-empty">{{localize "NEXUSNOTES.Panel.NoNotes"}}</p>
        {{/if}}
      </div>
    </section>

    {{!-- ── PARTY NOTES ──────────────────────────────────────────────── --}}
    <section class="nexus-section">
      <div class="nexus-section-header">
        <h3>{{localize "NEXUSNOTES.Panel.PartyNotes"}}</h3>
      </div>
      <div class="notes-list">
        {{#if partyNotes.length}}
          {{#each partyNotes}}
            <div class="note-card" data-note-id="{{id}}">
              <div class="note-card-main">
                <div class="note-card-title">
                  <span>{{title}}</span>
                  <span class="vis-badge vis-party">party</span>
                </div>
                <div class="note-author">
                  <i class="fa-solid fa-user-pen"></i> {{_authorName}}
                </div>
                {{#if _subject}}
                  <div class="note-subject">
                    <i class="fa-solid {{_subject.icon}}"></i>
                    <span>{{_subject.label}}</span>
                  </div>
                {{/if}}
                {{#if tags.length}}
                  <div class="note-tags">
                    {{#each tags}}<span class="tag-chip">{{this}}</span>{{/each}}
                  </div>
                {{/if}}
              </div>
              {{#if ../isGM}}
                <div class="note-card-actions">
                  <button type="button" class="nexus-btn-icon"
                          data-action="editNote"
                          data-vault-id="{{_vaultId}}"
                          data-note-id="{{id}}"
                          title="{{localize 'NEXUSNOTES.Action.Edit'}}">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </button>
                </div>
              {{/if}}
            </div>
          {{/each}}
        {{else}}
          <p class="nexus-empty">{{localize "NEXUSNOTES.Panel.NoPartyNotes"}}</p>
        {{/if}}
      </div>
    </section>

    {{!-- ── GM ALL VAULTS ────────────────────────────────────────────── --}}
    {{#if isGM}}
      <section class="nexus-section">
        <div class="nexus-section-header">
          <h3>{{localize "NEXUSNOTES.Panel.AllVaults"}}</h3>
        </div>
        <div class="nexus-vault-tabs">
          {{#each gmVaults}}
            <button type="button"
                    class="vault-tab {{#if active}}active{{/if}}"
                    data-action="switchVault"
                    data-vault-id="{{id}}">
              {{name}}
            </button>
          {{/each}}
        </div>
        {{#each gmVaults}}
          {{#if active}}
            <div class="notes-list">
              {{#if notes.length}}
                {{#each notes}}
                  <div class="note-card {{#if pinned}}is-pinned{{/if}}" data-note-id="{{id}}">
                    <div class="note-card-main">
                      <div class="note-card-title">
                        {{#if pinned}}<i class="fa-solid fa-thumbtack pin-icon"></i>{{/if}}
                        <span>{{title}}</span>
                        <span class="vis-badge vis-{{visibility}}">{{visibility}}</span>
                      </div>
                      {{#if _subject}}
                        <div class="note-subject">
                          <i class="fa-solid {{_subject.icon}}"></i>
                          <span>{{_subject.label}}</span>
                        </div>
                      {{/if}}
                      {{#if tags.length}}
                        <div class="note-tags">
                          {{#each tags}}<span class="tag-chip">{{this}}</span>{{/each}}
                        </div>
                      {{/if}}
                    </div>
                    <div class="note-card-actions">
                      <button type="button" class="nexus-btn-icon"
                              data-action="editNote"
                              data-vault-id="{{../../id}}"
                              data-note-id="{{id}}"
                              title="{{localize 'NEXUSNOTES.Action.Edit'}}">
                        <i class="fa-solid fa-pen-to-square"></i>
                      </button>
                      <button type="button" class="nexus-btn-icon {{#if pinned}}active{{/if}}"
                              data-action="togglePin"
                              data-vault-id="{{../../id}}"
                              data-note-id="{{id}}"
                              title="{{localize 'NEXUSNOTES.Action.TogglePin'}}">
                        <i class="fa-solid fa-thumbtack"></i>
                      </button>
                      <button type="button" class="nexus-btn-icon nexus-btn-danger"
                              data-action="deleteNote"
                              data-vault-id="{{../../id}}"
                              data-note-id="{{id}}"
                              title="{{localize 'NEXUSNOTES.Action.Delete'}}">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <p class="nexus-empty">{{localize "NEXUSNOTES.Panel.NoNotes"}}</p>
              {{/if}}
            </div>
          {{/if}}
        {{/each}}
      </section>
    {{/if}}

  {{/if}}{{!-- end noGM --}}
</div>
